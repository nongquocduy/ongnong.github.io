<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Speed I AM NHT - Clone UI</title>
  <style>
    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    body {
      min-height: 100vh;
      font-family: Arial, Helvetica, sans-serif;
      background: radial-gradient(circle at top, #1f2937 0, #050505 42%, #000 100%);
      color: #fff;
      padding: 18px 12px 50px;
    }

    .page {
      width: min(430px, 100%);
      margin: 0 auto;
    }

    .hero {
      text-align: center;
      padding: 18px 12px 22px;
    }

    .logo {
      width: 104px;
      height: 104px;
      margin: 0 auto 12px;
      border-radius: 28px;
      background: linear-gradient(135deg, #111827, #3b82f6, #22c55e);
      display: grid;
      place-items: center;
      box-shadow: 0 0 28px rgba(59, 130, 246, 0.55);
      border: 2px solid rgba(255, 255, 255, 0.25);
      overflow: hidden;
    }

    .logo img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }

    .logo span {
      font-size: 34px;
      font-weight: 900;
      letter-spacing: -2px;
    }

    h1 {
      font-size: 25px;
      letter-spacing: 1px;
      text-transform: uppercase;
      text-shadow: 0 0 16px rgba(255, 255, 255, 0.35);
    }

    .subtitle {
      margin-top: 8px;
      font-size: 13px;
      color: #cbd5e1;
    }

    .card {
      margin: 12px 0;
      border-radius: 18px;
      overflow: hidden;
      background: rgba(15, 23, 42, 0.82);
      border: 1px solid rgba(255, 255, 255, 0.12);
      box-shadow: 0 10px 28px rgba(0, 0, 0, 0.45);
      backdrop-filter: blur(10px);
    }

    .toggle {
      width: 100%;
      border: 0;
      color: #fff;
      cursor: pointer;
      padding: 15px 16px;
      font-weight: 800;
      font-size: 15px;
      text-transform: uppercase;
      background: linear-gradient(90deg, #111827, #1d4ed8);
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
    }

    .toggle .arrow {
      transition: transform 0.25s ease;
    }

    .card.open .toggle .arrow {
      transform: rotate(180deg);
    }

    .content {
      max-height: 0;
      overflow: hidden;
      transition: max-height 0.3s ease;
      background: rgba(2, 6, 23, 0.7);
    }

    .card.open .content {
      max-height: 900px;
    }

    .inner {
      padding: 15px;
    }

    .banner {
      width: 100%;
      min-height: 130px;
      border-radius: 16px;
      margin-bottom: 12px;
      background: linear-gradient(135deg, #020617, #2563eb 55%, #22c55e);
      display: grid;
      place-items: center;
      color: white;
      font-size: 21px;
      font-weight: 900;
      text-align: center;
      padding: 20px;
      border: 1px solid rgba(255,255,255,0.16);
    }

    .btn {
      width: 100%;
      display: block;
      text-align: center;
      margin-top: 10px;
      padding: 13px 14px;
      border-radius: 14px;
      border: 1px solid rgba(255, 255, 255, 0.14);
      background: #2563eb;
      color: #fff;
      text-decoration: none;
      font-weight: 800;
      cursor: pointer;
      transition: transform 0.18s ease, filter 0.18s ease;
    }

    .btn:hover {
      transform: translateY(-1px);
      filter: brightness(1.12);
    }

    .btn.green { background: #16a34a; }
    .btn.red { background: #dc2626; }
    .btn.dark { background: #111827; }
    .btn.purple { background: #7c3aed; }

    .item {
      padding: 12px 0;
      border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    }

    .item:last-child {
      border-bottom: 0;
    }

    .item-title {
      font-weight: 900;
      font-size: 16px;
      margin-bottom: 7px;
    }

    .version,
    .muted {
      color: #cbd5e1;
      font-size: 13px;
      margin-bottom: 8px;
    }

    .status {
      display: inline-flex;
      align-items: center;
      gap: 7px;
      color: #cbd5e1;
      font-size: 14px;
      margin-bottom: 10px;
    }

    .dot {
      width: 9px;
      height: 9px;
      border-radius: 999px;
      background: #22c55e;
      box-shadow: 0 0 12px #22c55e;
    }

    .dot.maintenance {
      background: #f59e0b;
      box-shadow: 0 0 12px #f59e0b;
    }

    .password-box {
      background: rgba(255,255,255,0.07);
      border: 1px solid rgba(255,255,255,0.1);
      border-radius: 14px;
      padding: 12px;
      margin-top: 10px;
    }

    .password-line {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 10px;
      font-weight: 800;
    }

    .password-value {
      margin-top: 10px;
      padding: 11px;
      border-radius: 11px;
      background: #020617;
      color: #93c5fd;
      font-family: Consolas, monospace;
      display: none;
      word-break: break-all;
    }

    .video-box {
      width: 100%;
      aspect-ratio: 16 / 9;
      border-radius: 16px;
      background: #020617;
      border: 1px solid rgba(255,255,255,0.12);
      display: grid;
      place-items: center;
      margin: 10px 0 14px;
      color: #cbd5e1;
      font-size: 42px;
    }

    .toast {
      position: fixed;
      left: 50%;
      bottom: 22px;
      transform: translateX(-50%) translateY(120px);
      background: #16a34a;
      color: #fff;
      padding: 12px 18px;
      border-radius: 999px;
      font-weight: 800;
      box-shadow: 0 10px 30px rgba(0,0,0,0.35);
      transition: transform 0.25s ease;
      z-index: 99;
    }

    .toast.show {
      transform: translateX(-50%) translateY(0);
    }

    footer {
      text-align: center;
      margin-top: 24px;
      color: #94a3b8;
      font-size: 12px;
    }
  </style>
</head>
<body>
  <main class="page">
    <section class="hero">
      <div class="logo">
        <!-- Thay bằng ảnh logo nếu muốn: <img src="logo.png" alt="Logo"> -->
        <span>NHT</span>
      </div>
      <h1>Speed I AM NHT</h1>
      <p class="subtitle">Trang tổng hợp link tải, chứng chỉ, DNS và hướng dẫn</p>
    </section>

    <section class="card open">
      <button class="toggle" type="button">ESIGN AXITAT <span class="arrow">▼</span></button>
      <div class="content">
        <div class="inner">
          <div class="banner">ESIGN AXITAT</div>
          <a class="btn" href="#">CÀI ĐẶT ESIGN AXITAT</a>
          <a class="btn green" href="#">TẢI CHỨNG CHỈ AXITAT</a>
        </div>
      </div>
    </section>

    <section class="card">
      <button class="toggle" type="button">ESIGN BEIJING <span class="arrow">▼</span></button>
      <div class="content">
        <div class="inner">
          <div class="banner">ESIGN BEIJING</div>
          <a class="btn" href="#">CÀI ĐẶT ESIGN BEIJING</a>
          <a class="btn green" href="#">TẢI CHỨNG CHỈ BEIJING</a>
        </div>
      </div>
    </section>

    <section class="card">
      <button class="toggle" type="button">MẬT KHẨU CHỨNG CHỈ <span class="arrow">▼</span></button>
      <div class="content">
        <div class="inner">
          <div class="password-box">
            <div class="password-line">
              <span>XEM MẬT KHẨU AXITAT ▶</span>
              <button class="btn dark" style="width:auto;margin:0" onclick="copyText('matkhau-axitat')">SAO CHÉP</button>
            </div>
            <div id="matkhau-axitat" class="password-value">NHAP_MAT_KHAU_AXITAT_O_DAY</div>
            <button class="btn purple" onclick="togglePassword('matkhau-axitat')">ẨN / HIỆN MẬT KHẨU</button>
          </div>

          <div class="password-box">
            <div class="password-line">
              <span>XEM MẬT KHẨU BEIJING ▶</span>
              <button class="btn dark" style="width:auto;margin:0" onclick="copyText('matkhau-beijing')">SAO CHÉP</button>
            </div>
            <div id="matkhau-beijing" class="password-value">NHAP_MAT_KHAU_BEIJING_O_DAY</div>
            <button class="btn purple" onclick="togglePassword('matkhau-beijing')">ẨN / HIỆN MẬT KHẨU</button>
          </div>
        </div>
      </div>
    </section>

    <section class="card">
      <button class="toggle" type="button">DNS CHẶN THU HỒI <span class="arrow">▼</span></button>
      <div class="content">
        <div class="inner">
          <div class="status"><span class="dot maintenance"></span> đang bảo trì</div>
          <p class="muted">● Chống thu hồi chứng chỉ • ESIGN</p>
          <a class="btn green" href="#">TẢI DNS NGAY</a>
        </div>
      </div>
    </section>

    <section class="card">
      <button class="toggle" type="button">LINK UPDATE SPEED 4 IN 1 <span class="arrow">▼</span></button>
      <div class="content">
        <div class="inner">
          <a class="btn" href="#">● MỞ LINK TẢI SPEED 4 IN 1</a>
          <button class="btn dark" onclick="copyCustom('https://example.com/speed-4-in-1')">COPY LINK SPEED 4 IN 1</button>
        </div>
      </div>
    </section>

    <section class="card">
      <button class="toggle" type="button">SPEED IGG <span class="arrow">▼</span></button>
      <div class="content">
        <div class="inner">
          <div class="item">
            <div class="item-title">SPEED ● IGG</div>
            <div class="version">Phiên bản: 3.5.2500</div>
            <button class="btn dark" onclick="copyCustom('https://example.com/speed-igg')">● COPY LINK ● SPEED IGG</button>
          </div>
          <a class="btn green" href="#">● NHÓM ZALO CẬP NHẬT SPEED</a>
          <a class="btn" href="#">● TELEGRAM CẬP NHẬT SPEED</a>
        </div>
      </div>
    </section>

    <section class="card">
      <button class="toggle" type="button">SPEED ĐẾM VÒNG ● V1 - V2 <span class="arrow">▼</span></button>
      <div class="content">
        <div class="inner">
          <div class="item">
            <div class="item-title">ĐẾM VÒNG ● V1</div>
            <div class="version">Phiên bản: 3.5.2500</div>
            <button class="btn dark" onclick="copyCustom('https://example.com/v1')">● COPY LINK ● V1</button>
          </div>
          <div class="item">
            <div class="item-title">ĐẾM VÒNG ● V2</div>
            <div class="version">Phiên bản: 3.5.2500</div>
            <button class="btn dark" onclick="copyCustom('https://example.com/v2')">● COPY LINK ● V2</button>
          </div>
          <a class="btn green" href="#">● NHÓM ZALO CẬP NHẬT SPEED</a>
          <a class="btn" href="#">TELEGRAM CẬP NHẬT SPEED</a>
        </div>
      </div>
    </section>

    <section class="card">
      <button class="toggle" type="button">SPEED PLUS VIP <span class="arrow">▼</span></button>
      <div class="content">
        <div class="inner">
          <div class="item-title">SPEED ● PLUS</div>
          <div class="version">3.5.2500</div>
          <button class="btn dark" onclick="copyCustom('https://example.com/speed-plus')">● COPY LINK SPEED PLUS</button>
          <a class="btn green" href="#">● NHÓM ZALO PLUS</a>
          <a class="btn" href="#">● TELEGRAM PLUS</a>
          <a class="btn red" href="#">● LIÊN HỆ MUA VIP</a>
        </div>
      </div>
    </section>

    <section class="card">
      <button class="toggle" type="button">VIDEO HƯỚNG DẪN ● COIN MASTER <span class="arrow">▼</span></button>
      <div class="content">
        <div class="inner">
          <div class="video-box">▶</div>
          <a class="btn" href="#">● Tải Esign Speed Free</a>
          <div class="video-box">▶</div>
          <a class="btn green" href="#">● Hướng dẫn cập nhật</a>
        </div>
      </div>
    </section>

    <footer>© 2026 - Demo giao diện tương tự. Thay toàn bộ link # bằng link thật của bạn.</footer>
  </main>

  <div id="toast" class="toast">Đã sao chép!</div>

  <script>
    const cards = document.querySelectorAll('.card');

    cards.forEach((card) => {
      const button = card.querySelector('.toggle');
      button.addEventListener('click', () => {
        card.classList.toggle('open');
      });
    });

    function showToast(message = 'Đã sao chép!') {
      const toast = document.getElementById('toast');
      toast.textContent = message;
      toast.classList.add('show');
      setTimeout(() => toast.classList.remove('show'), 1600);
    }

    function togglePassword(id) {
      const el = document.getElementById(id);
      el.style.display = el.style.display === 'block' ? 'none' : 'block';
    }

    async function copyText(id) {
      const el = document.getElementById(id);
      const text = el.textContent.trim();
      await navigator.clipboard.writeText(text);
      showToast('Đã sao chép mật khẩu!');
    }

    async function copyCustom(text) {
      await navigator.clipboard.writeText(text);
      showToast('Đã sao chép link!');
    }
  </script>
</body>
</html>
